[dev/appengine][arran4com datastore emulator]
command=gcloud beta emulators datastore start --project arran4com
name=arran4com datastore emulator
tooltip=

[dev/flutter][flutter run builder]
command=flutter pub run build_runner build
name=flutter run builder
tooltip=

[dev/git][git fetch all and prune]
command=git fetch --all --prune && git remote prune origin
name=git fetch all and prune
tooltip=

[dev/git][git interactive rebase master]
command=git rebase -i origin/master
name=git interactive rebase master
tooltip=

[dev/git][git log --oneline --graph --decorate]
command=git log --oneline --graph --decorate
name=git log --oneline --graph --decorate
tooltip=

[dev/go][go test vet fix lint format]
command=go test ./... && go vet ./... && go fix ./... && golangci-lint run && go fmt ./...
name=go test vet fix lint format
tooltip=

[dev][gh release push]
command=gh-release.sh patch
name=gh release push
tooltip=

[dev][git add ammend commit no edit tag release push tags and force push]
command=git add . && git commit --amend --no-edit && git-tag-inc release && git push --tags && git push --force
name=git add ammend commit no edit tag release push tags and force push
tooltip=

[dev][git-tag-inc release push]
command=git-tag-inc release && git push --tags
name=git-tag-inc release push
tooltip=

[docker][docker compose up build]
command=docker compose up -d --build
name=docker compose up build
tooltip=

[docker][docker prune system and volumes]
command=docker system prune -a --volumes -f
name=docker prune system and volumes
tooltip=

[docker][docker stop and remove all containers]
command=docker stop $(docker ps -aq) && docker rm $(docker ps -aq)
name=docker stop and remove all containers
tooltip=

[download][wget continue list.txt notify]
command=wget --continue --input-file=list.txt --content-disposition --trust-server-names --retry-connrefused; notify-send "wget"
name=wget continue list.txt notify
tooltip=

[media][mpv play clipboard]
command=mpv "$(wl-paste)"
name=mpv play clipboard
tooltip=

[system][chezmoi apply and notify]
command=chezmoi apply && notify-send "Chezmoi" "Apply completed"
name=chezmoi apply and notify
tooltip=

[system][chezmoi update apply init]
command=chezmoi update --apply --init
name=chezmoi update apply init
tooltip=

[system][update font cache]
command=fc-cache -fv
name=update font cache
tooltip=


{{- if eq .chezmoi.os "linux" -}}
{{- if hasKey .chezmoi "osRelease" -}}
{{- if eq .chezmoi.osRelease.id "gentoo" -}}
[gentoo][emerge sync world ask upgrade newuse with bdeps keepgoing notify]
command=sudo emerge --sync && sudo emerge -avuDNU --with-bdeps=y @world --keep-going=y; notify-send "Emerge world done"
name=emerge sync world ask upgrade newuse with bdeps keepgoing notify
tooltip=

[gentoo][emerge world ask deep new-use new upgrade keep going and notify afterwards]
command=sudo emerge @world -vauDNU --keep-going=y ; notify-send "Emerge world done"
name=emerge world ask deep new-use new upgrade keep going and notify afterwards
tooltip=

[gentoo][emerge world update ask]
command=sudo emerge -vau @world
name=emerge world update ask
tooltip=

[gentoo][emerge world update new-use new-deps deep ask keepgoing]
command=sudo emerge -vauUDN @world --keep-going=y
name=emerge world update new-use new-deps deep ask keepgoing
tooltip=


[gentoo][emerge sync and notify]
command=sudo emerge --sync && notify-send "Emerge" "Sync complete"
name=emerge sync and notify
tooltip=

[gentoo][eclean distfiles and depclean]
command=sudo eclean-dist -d && sudo emerge --depclean && notify-send "Emerge" "Cleanup complete"
name=eclean distfiles and depclean
tooltip=

[gentoo][revdep-rebuild and module rebuild]
command=sudo revdep-rebuild && sudo emerge @module-rebuild && notify-send "Emerge" "Rebuilds complete"
name=revdep-rebuild and module rebuild
tooltip=

{{- end -}}{{- end -}}{{- end -}}
